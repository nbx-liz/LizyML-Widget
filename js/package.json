{
  "name": "lizyml-widget-js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "esbuild src/index.tsx --bundle --format=esm --jsx=automatic --jsx-import-source=preact --outfile=../src/lizyml_widget/static/widget.js --sourcemap --watch",
    "build": "esbuild src/index.tsx --bundle --format=esm --jsx=automatic --jsx-import-source=preact --outfile=../src/lizyml_widget/static/widget.js --minify && cp src/widget.css ../src/lizyml_widget/static/widget.css",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "preact": "^10.29.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/preact": "^3.2.4",
    "@vitest/coverage-v8": "^2.1.9",
    "esbuild": "^0.28.0",
    "eslint": "^10.1.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^2.1.9"
  }
}
